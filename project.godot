; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Healthgochi"
run/main_scene="uid://npwgpbxaud2i"
config/features=PackedStringArray("4.6")
run/low_processor_mode=true
config/icon="res://icon.svg"

[autoload]

NotificationHandler="*res://globals/notification_handler.gd"
Stats="*uid://dncp7c7kk5j5j"
PageManager="*uid://dcv7rathwyh1y"
Remapper="*uid://cl8p42dhes0du"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/NotificationSchedulerPlugin/plugin.cfg", "res://addons/neon_page_controller/plugin.cfg", "res://addons/neon_scene_runner/plugin.cfg")

[input]

back={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
